# Coco environment configuration — copy to `.env` and fill in your own values.
# NEVER commit a real `.env` (it is git-ignored).

# ── Self-hosted / privacy-preserving backends ─────────────────────────────────────────
# Prefix a model id to route it to a non-cloud backend (see
# lib/external_api/README.md#model-providers). All keep data off third-party
# clouds to varying degrees.
#
# vLLM — your own OpenAI-compatible server, via LiteLLM. Use a
# `hosted_vllm/<model>` id (e.g. hosted_vllm/meta-llama/Llama-3.3-70B-Instruct)
# and point this at its /v1 endpoint. HOSTED_VLLM_API_KEY is optional (many
# self-hosted servers don't require one).
# HOSTED_VLLM_API_BASE="http://localhost:8000/v1"
# HOSTED_VLLM_API_KEY="your-vllm-api-key"
#
# LM Studio — local server (default host localhost:1234); use `lm_studio/<model>`.
# LM_STUDIO_HOST="localhost:1234"
#
# Tinfoil — confidential enclaves; use `tinfoil/<model>`.
# TINFOIL_API_KEY="your-tinfoil-api-key"
#
# Open Anonymity Project — unlinkable relay; use `oa/<model>`.
# OA_TICKET_FILE="/absolute/path/to/oa_tickets"
# OA_DESTINATION="openrouter"
# OA_BASE_URL="https://…"

# ── Cloud LLM providers ────────────────────────────────────────────────────────────
# GEMINI_API_KEY="your-gemini-api-key"
# GOOGLE_API_KEY="your-google-api-key"
# ANTHROPIC_API_KEY="your-anthropic-api-key"
# OPENAI_API_KEY="your-openai-api-key"
# ... (add more as needed)

# ── Records / training data ──────────────────────────────────────────────────
# Shared directory where sensing + tutor write their JSONL logs. When Coco is
# launched from the desktop app this defaults to `coco-records/` inside the
# app's user-data folder (next to your memory and settings); set this only to
# override that location.
# COCO_RECORDS_DIR="/absolute/path/to/records"
#
# Data mode — TWO modes, controlled by this one flag:
#   • Normal usage (default, flag unset): screenshots are deleted the moment the
#     observer has read them, so nothing accumulates on disk.
#   • Training-collection mode (flag = 1): screenshots are copied into
#     COCO_RECORDS_DIR before deletion so they can be used to improve the model.
#     This is privacy-sensitive and disk-heavy — enable it only deliberately.
# COLLECT_TRAINING_SCREENSHOTS=1